# Claude Code local overrides (per-user state, not project-wide config)
.claude/settings.local.json
.claude/.credentials.json
.claude/cc-sessions/

# Environment / secrets — never commit
.env
.env.*
!.env.example
*.pem
*.key
id_ed25519
id_ed25519.pub
authorized_keys

# Manifest/state produced by the setup script at runtime
# (only relevant if this repo is cloned directly onto the VPS)
/var/lib/vps-setup/

# Editor + IDE cruft
*~
*.swp
*.swo
*.bak
*.orig
.idea/
.vscode/
.nvimlog

# OS cruft
.DS_Store
Thumbs.db
desktop.ini

# Ad-hoc runtime artefacts
*.log
/tmp/
